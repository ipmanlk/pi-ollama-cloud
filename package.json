{
  "name": "pi-ollama-cloud",
  "version": "0.4.1",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "index.ts",
    "config.ts",
    "models.ts",
    "models.generated.ts",
    "thinking-levels.ts",
    "utils.ts",
    "web-tools.ts",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fgrehm/pi-ollama-cloud"
  },
  "scripts": {
    "check": "biome check --write .",
    "lint": "biome check .",
